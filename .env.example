# =============================================================================
# COPY THIS FILE TO `.env` FOR LOCAL DEVELOPMENT (never commit `.env`)
# =============================================================================
#
# ── Supabase (Auth + Postgres via JS client) ────────────────────────────────
# Dashboard → Project Settings → API
#   • Project URL → VITE_SUPABASE_URL (browser) and SUPABASE_URL (server, same value)
#   • anon public → VITE_SUPABASE_ANON_KEY (browser) and SUPABASE_ANON_KEY (server)
# This backend uses anon + user JWT + RLS policies (no service_role key required).
#
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
#
# Optional: duplicate the URL/anon values using VITE_* so the SPA can use the same
# Supabase project from the browser later (e.g. direct Supabase Realtime).
# VITE_SUPABASE_URL=   (same as SUPABASE_URL)
# VITE_SUPABASE_ANON_KEY=   (same as SUPABASE_ANON_KEY)

# ── Session cookies (Express API) ───────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET="long-random-string-for-production"

# ── Local API (npm run dev) ─────────────────────────────────────────────────
API_PORT=3001

# ── Vite / browser (optional) ───────────────────────────────────────────────
# Public site URL (optional — links, redirects, future OAuth)
# VITE_APP_URL=https://your-app.vercel.app
# Same deployment on Vercel: leave empty so `/api` calls the same origin.
# VITE_API_URL=

# ── Vercel (Dashboard → Environment Variables) ───────────────────────────────
# Production + Preview: SESSION_SECRET, SUPABASE_URL, SUPABASE_ANON_KEY
# Optional mirrors: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_APP_URL
# Build: npm run build:vercel (see vercel.json)
#
# Database schema: run `supabase/migrations/20260221190000_app_schema.sql` once in the
# Supabase SQL Editor (creates `profiles`, app tables, and auth.users → profile trigger).

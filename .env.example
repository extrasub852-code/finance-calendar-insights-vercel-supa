# Local development (SQLite file). Used by Prisma CLI (migrate, db push, generate).
# On Railway with Turso only, you can omit this — the server sets a placeholder when TURSO_* are set.
DATABASE_URL="file:./prisma/dev.db"

# API server port
API_PORT=3001

# Session cookie signing (set a long random string in production)
SESSION_SECRET="change-me-in-production"

# --- Turso (production / hosted DB) ---
# When BOTH are set, the API uses Turso via the libSQL driver instead of the file above.
# Get URL + token: https://docs.turso.tech/cli/authentication — then: turso db show --url
# TURSO_DATABASE_URL="libsql://your-db-org.turso.io"
# TURSO_AUTH_TOKEN="eyJ..."
#
# First-time Turso setup (empty database):
#   turso db shell <your-database-name> < prisma/turso-init-schema.sql
# Copy local prisma/dev.db data into Turso:
#   npm run db:turso:copy
